# Copy to .env and fill in your own values.  .env is gitignored — never commit real secrets.
# Either `=` or `:` separators work (the loader accepts both).

# --- Anypoint / CloudHub (required only for log validation: validate_logs=Yes) ---
# Plain lowercase keys (no ALT_ prefix). client_secret is sensitive — keep it out of git.
# Use the deployment BASE url (.../deployments/<DEPLOYMENT_ID>); the live spec version and
# /logs/file path are resolved automatically. Point it at the deployment that serves your API
# (a wrong/old deployment id returns another app's logs and log validation will never match).
# This is the per-suite URL for a hand-written sheet; generated suites get it filled from
# deployments_base_url + the spec's deployment id (see below).
application_logs_fetch_url=https://anypoint.mulesoft.com/amc/application-manager/api/v2/organizations/<ORG_ID>/environments/<ENV_ID>/deployments/<DEPLOYMENT_ID>
# Deployments BASE (no deployment id). generate_test_suite / generate_and_run append
# "/<deployment-id>" parsed from the spec's servers[0].description to fill the suite's
# application_logs_fetch_url automatically.
deployments_base_url=https://anypoint.mulesoft.com/amc/application-manager/api/v2/organizations/<ORG_ID>/environments/<ENV_ID>/deployments
token_endpoint=https://anypoint.mulesoft.com/accounts/api/v2/oauth2/token
client_id=<YOUR_CONNECTED_APP_CLIENT_ID>
client_secret=<YOUR_CONNECTED_APP_CLIENT_SECRET>
grant_type=client_credentials

# --- Optional behaviour settings (ALT_ prefix) ---
# Mock file log backend (used when a case has log_source=file):
# ALT_FILE_LOG_PATH=tests/fixtures/sample_app.log
# Seconds to wait for logs to propagate before downloading (default 60):
# ALT_PROPAGATION_WAIT_SECONDS=60
# Re-fetch up to N times until each correlation id's logs appear (default 3), waiting between:
# ALT_LOG_FETCH_MAX_RETRIES=3
# ALT_LOG_FETCH_RETRY_WAIT_SECONDS=60
# If a request's correlation id isn't found in the logs, match against the whole log (default true):
# ALT_LOG_CORRELATION_FALLBACK=true
